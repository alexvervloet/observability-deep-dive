# Copy this file to `.env` and adjust if you want a real provider.
#
#   cp .env.example .env
#
# The default needs NO key — the whole repo runs offline. The traffic simulator
# generates weeks of synthetic request logs, and every metric, drift detector,
# alert, and the capstone dashboard run on those logs. No network, no cost.
# NEVER commit your real .env file. It is already in .gitignore.

# ---------------------------------------------------------------------------
# Which provider backs the OPTIONAL live bits (the sampled LLM-as-judge in the
# quality-drift section, and real embeddings for input-drift)?
#
#   mock   -> deterministic, offline judge + hash-based embeddings  (no key, default)
#   openai -> OpenAI (judge = gpt-4o-mini, embeddings = text-embedding-3-small)
#   claude -> Claude (judge = claude-haiku-4-5; embeddings still need OPENAI_API_KEY)
#
# Every core lesson — reading logs, baselines, drift, alerting, mining, the
# dashboard — runs identically on all three, because they analyze *logs*, not a
# live model. The provider only changes what grades the sampled slice.
# ---------------------------------------------------------------------------
PROVIDER=mock

# Flip PROVIDER to a real stack but forget `secrun` (so the key isn't on the
# environment) and the code won't crash — it degrades to the offline mock, loudly
# (a stderr banner + an "Active provider: mock (FALLBACK: ...)" line). That keeps
# you running, but it is NOT the real model. Set PROVIDER_STRICT=1 to turn the
# missing key back into a hard error instead — do this in CI and any run whose
# judge scores you intend to trust, where a silent mock would poison your numbers.
# PROVIDER_STRICT=1

# --- API keys (optional) are NOT stored here ---
# The default mock needs no key. To use a real provider, store its key in your OS
# keychain and inject it per-command with `secrun` (setup: ../SECRETS.md), then run
# key-using scripts as:  secrun python examples/...
#   PROVIDER=openai  needs  OPENAI_API_KEY     https://platform.openai.com/api-keys
#   PROVIDER=claude  needs  ANTHROPIC_API_KEY  https://console.anthropic.com/settings/keys
#   (embeddings for input-drift always use OPENAI_API_KEY when not on the mock.)
